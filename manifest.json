{
  "manifest_version": 3,
  "name": "Remarq",
  "version": "1.0.0",
  "description": "AI-powered comment generator for YouTube, Substack and LinkedIn. Highlight any text, pick a tone, generate in seconds.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.substack.com/*",
    "*://*.linkedin.com/*",
    "https://remarq-backend-production-fe13.up.railway.app/"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.substack.com/*",
        "*://*.linkedin.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
